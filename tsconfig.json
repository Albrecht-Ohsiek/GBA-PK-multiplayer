{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist"
  },
  "tstl": {
    "luaTarget": "5.3",
    "sourceMapTraceback": false, // Turn to true to make it easier to traceback error
    "noHeader": false
  },
  "include": ["src"]
}

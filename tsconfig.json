{
  "$schema": "https://raw.githubusercontent.com/TypeScriptToLua/TypeScriptToLua/master/tsconfig-schema.json",
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
  },
  "tstl": {
    "luaTarget": "5.3",
    "luaBundle": "./dist/artifacts/bundle.lua",
    "luaBundleEntry": "src/main.ts",
    "sourceMapTraceback": false, // Turn to true to make it easier to traceback error
    "noHeader": false
  },
  "files": [
    "src/main.ts"
  ]
}
